{% extends 'base.html' %}

{% block title %}Leave Details - HRM System{% endblock %}

{% block content %}
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <h1>Leave Request Details</h1>
    <a href="{% if user.is_staff %}{% url 'leave_requests' %}{% else %}{% url 'my_leaves' %}{% endif %}"
        class="btn btn-secondary">
        Back
    </a>
</div>

<div class="grid grid-2">
    <!-- Leave Information -->
    <div class="card">
        <div class="card-header">Leave Information</div>
        <table class="table">
            <tr>
                <th style="width: 40%;">Employee</th>
                <td><strong>{{ leave_request.employee.get_full_name }}</strong></td>
            </tr>
            <tr>
                <th>Employee ID</th>
                <td>{{ leave_request.employee.employee_id }}</td>
            </tr>
            <tr>
                <th>Leave Type</th>
                <td>{{ leave_request.leave_type.name }}</td>
            </tr>
            <tr>
                <th>Start Date</th>
                <td>{{ leave_request.start_date|date:"l, F d, Y" }}</td>
            </tr>
            <tr>
                <th>End Date</th>
                <td>{{ leave_request.end_date|date:"l, F d, Y" }}</td>
            </tr>
            <tr>
                <th>Total Days</th>
                <td><strong>{{ leave_request.total_days }} day{{ leave_request.total_days|pluralize }}</strong></td>
            </tr>
            <tr>
                <th>Status</th>
                <td>
                    {% if leave_request.status == "PE" %}
                    <span class="badge badge-warning">⏳ Pending</span>
                    {% elif leave_request.status == "AP" %}
                    <span class="badge badge-success">✓ Approved</span>
                    {% elif leave_request.status == "RJ" %}
                    <span class="badge badge-danger">✗ Rejected</span>
                    {% elif leave_request.status == "CA" %}
                    <span class="badge badge-secondary">Cancelled</span>
                    {% endif %}
                </td>
            </tr>
        </table>
    </div>

    <!-- Request Details -->
    <div class="card">
        <div class="card-header">Request Details</div>
        <table class="table">
            <tr>
                <th style="width: 40%;">Applied On</th>
                <td>{{ leave_request.created_at|date:"M d, Y H:i" }}</td>
            </tr>
            {% if leave_request.approved_by %}
            <tr>
                <th>Reviewed By</th>
                <td>{{ leave_request.approved_by.get_full_name }}</td>
            </tr>
            <tr>
                <th>Reviewed On</th>
                <td>{{ leave_request.approved_at|date:"M d, Y H:i" }}</td>
            </tr>
            {% endif %}
        </table>

        {% if leave_request.reason %}
        <div style="margin-top: 1rem; padding: 1rem; background: var(--bg-light); border-radius: 0.375rem;">
            <p style="font-weight: 600; margin-bottom: 0.5rem;">Reason:</p>
            <p style="margin: 0;">{{ leave_request.reason }}</p>
        </div>
        {% endif %}

        {% if leave_request.approval_notes %}
        <div style="margin-top: 1rem; padding: 1rem; background: var(--bg-light); border-radius: 0.375rem;">
            <p style="font-weight: 600; margin-bottom: 0.5rem;">Admin Notes:</p>
            <p style="margin: 0;">{{ leave_request.approval_notes }}</p>
        </div>
        {% endif %}
    </div>
</div>

{% if user.is_staff and leave_request.status == "PE" %}
<!-- Admin Actions -->
<div class="card">
    <div class="card-header">Admin Actions</div>
    <div style="display: flex; gap: 1rem;">
        <form method="post" action="{% url 'leave_approve' leave_request.id %}" style="flex: 1;">
            {% csrf_token %}
            <div class="form-group">
                <label for="notes" class="form-label">Notes (Optional)</label>
                <textarea id="notes" name="notes" class="form-control" rows="3"
                    placeholder="Add any notes..."></textarea>
            </div>
            <button type="submit" class="btn btn-success" onclick="return confirm('Approve this leave request?')">
                ✓ Approve Leave
            </button>
        </form>

        <form method="post" action="{% url 'leave_reject' leave_request.id %}" style="flex: 1;">
            {% csrf_token %}
            <div class="form-group">
                <label for="notes" class="form-label">Rejection Reason (Optional)</label>
                <textarea id="notes" name="notes" class="form-control" rows="3"
                    placeholder="Reason for rejection..."></textarea>
            </div>
            <button type="submit" class="btn btn-danger" onclick="return confirm('Reject this leave request?')">
                ✗ Reject Leave
            </button>
        </form>
    </div>
</div>
{% endif %}
{% endblock %}