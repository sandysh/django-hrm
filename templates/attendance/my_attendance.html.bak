{% extends 'base.html' %}

{% block title %}My Attendance - HRM System{% endblock %}

{% block content %}
<h1>My Attendance History</h1>

<!-- Date Filter -->
<div class="card" style="margin-bottom: 1.5rem;">
    <form method="get" style="display: flex; gap: 1rem; align-items: end;">
        <div class="form-group" style="margin-bottom: 0;">
            <label for="start_date" class="form-label">From</label>
            <input type="date" id="start_date" name="start_date" class="form-control" value="{{ start_date }}">
        </div>

        <div class="form-group" style="margin-bottom: 0;">
            <label for="end_date" class="form-label">To</label>
            <input type="date" id="end_date" name="end_date" class="form-control" value="{{ end_date }}">
        </div>

        <button type="submit" class="btn btn-primary">Filter</button>
    </form>
</div>

<!-- Statistics -->
<div class="grid grid-4">
    <div class="stat-card" style="background: linear-gradient(135deg, #10B981 0%, #059669 100%);">
        <h3>{{ present_days }}</h3>
        <p>Present Days</p>
    </div>

    <div class="stat-card" style="background: linear-gradient(135deg, #EF4444 0%, #DC2626 100%);">
        <h3>{{ absent_days }}</h3>
        <p>Absent Days</p>
    </div>

    <div class="stat-card" style="background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);">
        <h3>{{ late_days }}</h3>
        <p>Late Arrivals</p>
    </div>

    <div class="stat-card" style="background: linear-gradient(135deg, #4F46E5 0%, #4338CA 100%);">
        <h3>{{ total_hours }}</h3>
        <p>Total Hours</p>
    </div>
</div>

<!-- Attendance Records -->
<div class="card">
    <div class="card-header">Attendance Records</div>

    {% if attendance_records %}
    <table class="table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Check In</th>
                <th>Check Out</th>
                <th>Hours</th>
                <th>Overtime</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            {% for record in attendance_records %}
            <tr>
                <td><strong>{{ record.date|date:"D, M d, Y" }}</strong></td>
                <td>
                    {{ record.check_in_time|default:"--:--" }}
                    {% if record.is_late %}
                    <span class="badge badge-warning" style="margin-left: 0.5rem;">Late</span>
                    {% endif %}
                </td>
                <td>{{ record.check_out_time|default:"--:--" }}</td>
                <td>{{ record.total_hours|default:"0.0" }}</td>
                <td>{{ record.overtime_hours|default:"0.0" }}</td>
                <td>
                    {% if record.status == 'PR' %}
                    <span class="badge badge-success">Present</span>
                    {% elif record.status == 'LT' %}
                    <span class="badge badge-warning">Late</span>
                    {% elif record.status == 'AB' %}
                    <span class="badge badge-danger">Absent</span>
                    {% elif record.status == 'HL' %}
                    <span class="badge badge-info">Half Day</span>
                    {% elif record.status == 'LV' %}
                    <span class="badge badge-secondary">On Leave</span>
                    {% endif %}
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% else %}
    <p style="text-align: center; padding: 3rem; color: var(--text-secondary);">
        No attendance records found for the selected period.
    </p>
    {% endif %}
</div>
{% endblock %}