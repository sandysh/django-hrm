{% extends 'base.html' %}

{% block title %}{{ action }} Employee - HRM System{% endblock %}

{% block content %}
<h1>{{ action }} Employee</h1>

<div class="card">
    <form method="post">
        {% csrf_token %}

        <div class="grid grid-2">
            <div class="form-group">
                <label for="employee_id" class="form-label">Employee ID *</label>
                <input type="text" id="employee_id" name="employee_id" class="form-control"
                    value="{{ employee.employee_id|default:'' }}" required>
            </div>

            <div class="form-group">
                <label for="username" class="form-label">Username *</label>
                <input type="text" id="username" name="username" class="form-control"
                    value="{{ employee.username|default:'' }}" {% if employee %}disabled{% else %}required{% endif %}>
            </div>
        </div>

        <div class="grid grid-2">
            <div class="form-group">
                <label for="first_name" class="form-label">First Name *</label>
                <input type="text" id="first_name" name="first_name" class="form-control"
                    value="{{ employee.first_name|default:'' }}" required>
            </div>

            <div class="form-group">
                <label for="last_name" class="form-label">Last Name *</label>
                <input type="text" id="last_name" name="last_name" class="form-control"
                    value="{{ employee.last_name|default:'' }}" required>
            </div>
        </div>

        <div class="grid grid-2">
            <div class="form-group">
                <label for="email" class="form-label">Email</label>
                <input type="email" id="email" name="email" class="form-control"
                    value="{{ employee.email|default:'' }}">
            </div>

            <div class="form-group">
                <label for="phone_number" class="form-label">Phone Number</label>
                <input type="text" id="phone_number" name="phone_number" class="form-control"
                    value="{{ employee.phone_number|default:'' }}">
            </div>
        </div>

        <div class="grid grid-2">
            <div class="form-group">
                <label for="department" class="form-label">Department</label>
                <input type="text" id="department" name="department" class="form-control"
                    value="{{ employee.department|default:'' }}" placeholder="e.g., Engineering, HR, Sales">
            </div>

            <div class="form-group">
                <label for="designation" class="form-label">Designation</label>
                <input type="text" id="designation" name="designation" class="form-control"
                    value="{{ employee.designation|default:'' }}" placeholder="e.g., Developer, Manager">
            </div>
        </div>

        <div class="grid grid-2">
            <div class="form-group">
                <label for="employment_type" class="form-label">Employment Type</label>
                <select id="employment_type" name="employment_type" class="form-control">
                    <option value="FT" {% if employee.employment_type == 'FT' or not employee %}selected{% endif %}>Full
                        Time</option>
                    <option value="PT" {% if employee.employment_type == 'PT' %}selected{% endif %}>Part Time</option>
                    <option value="CT" {% if employee.employment_type == 'CT' %}selected{% endif %}>Contract</option>
                    <option value="IN" {% if employee.employment_type == 'IN' %}selected{% endif %}>Intern</option>
                </select>
            </div>

            <div class="form-group">
                <label for="status" class="form-label">Status</label>
                <select id="status" name="status" class="form-control">
                    <option value="AC" {% if employee.status == 'AC' or not employee %}selected{% endif %}>Active</option>
                    <option value="IN" {% if employee.status == 'IN' %}selected{% endif %}>Inactive</option>
                    <option value="TR" {% if employee.status == 'TR' %}selected{% endif %}>Terminated</option>
                </select>
            </div>
        </div>

        <div class="form-group">
            <label for="password" class="form-label">Password {% if not employee %}*{% else %}(leave blank to keep
                current){% endif %}</label>
            <input type="password" id="password" name="password" class="form-control" {% if not employee %}required{%
                endif %}>
        </div>

        <div class="form-group">
            <label style="display: flex; align-items: center; gap: 0.5rem;">
                <input type="checkbox" name="is_staff" {% if employee.is_staff %}checked{% endif %}>
                <span>Admin User (can access admin features)</span>
            </label>
        </div>

        <div style="display: flex; gap: 1rem; margin-top: 2rem;">
            <button type="submit" class="btn btn-primary">{{ action }} Employee</button>
            <a href="{% url 'employee_list' %}" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
{% endblock %}